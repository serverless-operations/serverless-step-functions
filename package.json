{
  "name": "serverless-step-functions",
  "version": "3.30.0",
  "description": "The module is AWS Step Functions plugin for Serverless Framework",
  "main": "lib/index.js",
  "scripts": {
    "test": "mocha \"lib/**/*.test.js\"",
    "coverage": "c8 --reporter=text --reporter=lcov npm test",
    "lint": "eslint .",
    "test:integration": "osls deploy --stage test",
    "semantic-release": "semantic-release"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/serverless-operations/serverless-step-functions.git"
  },
  "keywords": [
    "serverless"
  ],
  "author": "horike37",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/serverless-operations/serverless-step-functions/issues"
  },
  "homepage": "https://github.com/serverless-operations/serverless-step-functions#readme",
  "devDependencies": {
    "@commitlint/cli": "^17.6.1",
    "@commitlint/config-conventional": "^15.0.0",
    "c8": "^11.0.0",
    "chai": "^3.5.0",
    "eslint": "^10.0.0",
    "eslint-config-airbnb-extended": "^3.0.1",
    "globals": "^17.0.0",
    "husky": "^1.3.1",
    "lint-staged": "^13.2.1",
    "mocha": "^11.1.0",
    "mocha-param": "^2.0.0",
    "pkg-pr-new": "^0.0.54",
    "semantic-release": "^25.0.3",
    "osls": "^3.0.0",
    "sinon": "^12.0.1"
  },
  "dependencies": {
    "@osls/compose": "^1.4.0",
    "asl-validator": "^3.11.0",
    "bluebird": "^3.4.0",
    "chalk": "^4.1.2",
    "joi": "^17.7.0",
    "lodash": "^4.17.11"
  },
  "peerDependencies": {
    "serverless": ">=3.0.0"
  },
  "overrides": {
    "file-type": "17.1.3",
    "ansi-regex": "5.0.1",
    "simple-git": "3.5.0",
    "ramda": "0.27.2",
    "got": "11.8.5"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS"
    }
  },
  "lint-staged": {
    "*.js": [
      "eslint"
    ]
  },
  "engines": {
    "node": ">=22"
  }
}
